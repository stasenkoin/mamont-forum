{{!--
  Страница списка пользователей форума.
  Отображает заголовок, контейнер для динамически загружаемого списка
  пользователей и блок пагинации.
  Содержимое загружается и отрисовывается клиентским скриптом users-list.js.
--}}

<div class="page-header">
  <h1>Пользователи</h1>
</div>

{{!-- Контейнер для списка пользователей; содержимое подгружается динамически через JS --}}
<div id="users-list">
  <p class="empty">Загрузка...</p>
</div>

{{!-- Блок пагинации: кнопки "Назад" и "Вперёд", информация о текущей странице --}}
{{!-- Изначально скрыт; показывается после загрузки данных скриптом --}}
<div class="pagination" id="users-pagination" style="display:none">
  <button class="btn btn-sm" id="prev-page-btn">&larr; Назад</button>
  <span class="pagination-info" id="page-info"></span>
  <button class="btn btn-sm" id="next-page-btn">Вперёд &rarr;</button>
</div>

{{!-- Клиентский скрипт для загрузки списка пользователей через API и управления пагинацией --}}
<script src="/js/users-list.js"></script>
