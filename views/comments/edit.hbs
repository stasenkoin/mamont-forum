<h1>Редактирование комментария</h1>
<div class="alert alert-error" id="error-msg" style="display:none"></div>
<form class="form" id="edit-comment-form" data-discussion-id="{{discussionId}}" data-comment-id="{{comment.id}}">
  <label for="content">Комментарий</label>
  <textarea name="content" id="content" rows="6" required>{{comment.content}}</textarea>

  <button type="submit" class="btn btn-primary">Сохранить</button>
  <a href="/discussions/{{discussionId}}" class="btn btn-outline">Отмена</a>
</form>

<script src="/js/comment-edit.js"></script>
