{{!--
  Страница настроек аккаунта пользователя.
  Отображает информацию об аккаунте (загружается динамически через account.js),
  а также "опасную зону" с кнопками выхода из аккаунта и удаления аккаунта.
--}}

<h1>Настройки аккаунта</h1>

{{!-- Карточка с информацией об аккаунте; содержимое подгружается динамически через JS --}}
<div class="card" id="account-info">
  <p class="empty">Загрузка...</p>
</div>

{{!-- Опасная зона: действия, требующие осторожности --}}
<div class="danger-zone">
  <h2>Опасная зона</h2>

  {{!-- Кнопка выхода из аккаунта --}}
  <button class="btn btn-outline" id="logout-btn">Выйти из аккаунта</button>

  {{!-- Кнопка удаления аккаунта (необратимое действие) --}}
  <button class="btn btn-danger" id="delete-account-btn">Удалить аккаунт</button>
</div>

{{!-- Клиентский скрипт для загрузки данных аккаунта и обработки действий (выход, удаление) --}}
<script src="/js/account.js"></script>
