<h1>Настройки аккаунта</h1>
<div class="card" id="account-info">
  <p><strong>Никнейм:</strong> {{userInfo.nickname}}</p>
  {{#if userInfo.avatarUrl}}
    <p><strong>Аватар:</strong></p>
    <img src="{{userInfo.avatarUrl}}" alt="avatar" class="avatar-lg">
  {{/if}}
  <p><strong>Зарегистрирован:</strong> {{formatDate userInfo.createdAt}}</p>
</div>

<div class="danger-zone">
  <h2>Опасная зона</h2>
  <button class="btn btn-outline" id="logout-btn">Выйти из аккаунта</button>
  <button class="btn btn-danger" id="delete-account-btn">Удалить аккаунт</button>
</div>

<script src="/js/account.js"></script>
