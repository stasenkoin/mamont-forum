{{!--
  Страница входа в аккаунт (авторизации).
  Содержит форму с полями "Никнейм" и "Пароль",
  блок для отображения ошибок и ссылку на страницу регистрации.
  Отправка формы обрабатывается клиентским скриптом login.js.
--}}

<h1>Вход</h1>

{{!-- Блок для отображения сообщений об ошибках авторизации; изначально скрыт --}}
<div class="alert alert-error" id="error-msg" style="display:none"></div>

{{!-- Форма входа в аккаунт --}}
<form class="form" id="login-form">
  {{!-- Поле ввода никнейма пользователя --}}
  <label for="nickname">Никнейм</label>
  <input type="text" name="nickname" id="nickname" required>

  {{!-- Поле ввода пароля --}}
  <label for="password">Пароль</label>
  <input type="password" name="password" id="password" required>

  {{!-- Кнопка отправки формы входа --}}
  <button type="submit" class="btn btn-primary">Войти</button>

  {{!-- Ссылка на страницу регистрации для новых пользователей --}}
  <p>Нет аккаунта? <a href="/auth/register">Зарегистрироваться</a></p>
</form>

{{!-- Клиентский скрипт для обработки отправки формы авторизации через API --}}
<script src="/js/login.js"></script>
