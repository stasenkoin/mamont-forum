<h1>Редактирование обсуждения</h1>
<div class="alert alert-error" id="error-msg" style="display:none"></div>
<form class="form" id="edit-discussion-form" data-id="{{discussion.id}}">
  <label for="title">Заголовок</label>
  <input type="text" name="title" id="title" required value="{{discussion.title}}">

  <label for="content">Содержание</label>
  <textarea name="content" id="content" rows="8" required>{{discussion.content}}</textarea>

  <button type="submit" class="btn btn-primary">Сохранить</button>
  <a href="/discussions/{{discussion.id}}" class="btn btn-outline">Отмена</a>
</form>

<script src="/js/discussion-edit.js"></script>
