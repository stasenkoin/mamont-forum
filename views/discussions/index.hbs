{{!--
  Страница списка обсуждений (главная страница форума).
  Отображает заголовок, кнопку создания нового обсуждения (только для авторизованных),
  контейнер для динамически загружаемого списка обсуждений и блок пагинации.
  Содержимое списка загружается и отрисовывается клиентским скриптом discussions-list.js.
--}}

{{!-- Заголовок страницы и кнопка создания нового обсуждения --}}
<div class="page-header">
  <h1>Обсуждения</h1>
  {{!-- Кнопка "Новое обсуждение" отображается только для авторизованных пользователей --}}
  {{#if user}}
    <a href="/discussions/new" class="btn btn-primary">Новое обсуждение</a>
  {{/if}}
</div>

{{!-- Контейнер для списка обсуждений; содержимое подгружается динамически через JS --}}
<div id="discussions-list">
  <p class="empty">Загрузка...</p>
</div>

{{!-- Блок пагинации: кнопки "Назад" и "Вперёд", информация о текущей странице --}}
{{!-- Изначально скрыт; показывается после загрузки данных скриптом --}}
<div class="pagination" id="discussions-pagination" style="display:none">
  <button class="btn btn-sm" id="prev-page-btn">&larr; Назад</button>
  <span class="pagination-info" id="page-info"></span>
  <button class="btn btn-sm" id="next-page-btn">Вперёд &rarr;</button>
</div>

{{!-- Клиентский скрипт для загрузки списка обсуждений через API и управления пагинацией --}}
<script src="/js/discussions-list.js"></script>
