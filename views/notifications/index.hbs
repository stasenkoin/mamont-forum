<div class="page-header">
  <h1>Уведомления</h1>
  {{#if notifications.length}}
    <button class="btn btn-sm" id="read-all-btn">Прочитать все</button>
  {{/if}}
</div>

<div id="notifications-list">
  {{#if notifications.length}}
    {{#each notifications}}
      <div class="notification{{#unless this.isRead}} notification-unread{{/unless}}" id="notification-{{this.id}}">
        <div class="notification-content">
          <p>{{this.message}}</p>
          <span class="meta">{{formatDate this.createdAt}}</span>
          {{#if this.discussionId}}
            <a href="/discussions/{{this.discussionId}}" class="btn btn-sm">Перейти</a>
          {{/if}}
        </div>
        <div class="notification-actions">
          {{#unless this.isRead}}
            <button class="btn btn-sm mark-read-btn" data-id="{{this.id}}">Прочитано</button>
          {{/unless}}
          <button class="btn btn-sm btn-danger delete-notif-btn" data-id="{{this.id}}">Удалить</button>
        </div>
      </div>
    {{/each}}
  {{else}}
    <p class="empty">У вас нет уведомлений.</p>
  {{/if}}
</div>

<script src="/js/notifications-page.js"></script>
