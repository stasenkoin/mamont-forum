{{!--
  Страница списка уведомлений пользователя.
  Отображает заголовок, кнопку "Прочитать все" (для массовой пометки как прочитанных)
  и контейнер для динамически загружаемого списка уведомлений.
  Содержимое загружается и отрисовывается клиентским скриптом notifications-page.js.
--}}

<div class="page-header">
  <h1>Уведомления</h1>

  {{!-- Кнопка массовой пометки всех уведомлений как прочитанных; изначально скрыта --}}
  <button class="btn btn-sm" id="read-all-btn" style="display:none">Прочитать все</button>
</div>

{{!-- Контейнер для списка уведомлений; содержимое подгружается динамически через JS --}}
<div id="notifications-list">
  <p class="empty">Загрузка...</p>
</div>

{{!-- Клиентский скрипт для загрузки уведомлений через API и управления их состоянием --}}
<script src="/js/notifications-page.js"></script>
