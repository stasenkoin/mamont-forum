<header class="header">
  <div class="header-inner">
    <a href="/discussions" class="logo">&#128024; Mamont Forum</a>
    <nav class="header-links" id="header-links">
      <a href="/discussions" data-match="/discussions">Обсуждения</a>
      <a href="/users" data-match="/users">Пользователи</a>
      <a href="/rules" data-match="/rules">Правила</a>
    </nav>
    <script>
      (function () {
        var path = window.location.pathname;
        var links = document.querySelectorAll('#header-links a');
        links.forEach(function (link) {
          var match = link.getAttribute('data-match');
          if (path === match || path.indexOf(match + '/') === 0) {
            link.classList.add('active');
          }
        });
      })();
    </script>
    <nav class="header-nav">
      {{#if user}}
        <div class="notification-wrapper">
          <a href="/notifications" class="btn btn-sm" id="notification-btn">
            &#128276; <span id="notification-count"></span>
          </a>
        </div>
        <span class="user-info">
          {{#if user.avatarUrl}}
            <img src="{{user.avatarUrl}}" alt="avatar" class="avatar-sm">
          {{/if}}
          {{user.nickname}}
        </span>
        <a href="/account" class="btn btn-sm">Настройки</a>
        <button class="btn btn-sm btn-outline" onclick="fetch('/api/auth/logout',{method:'POST'}).then(function(){window.location.href='/'})">Выйти</button>
      {{else}}
        <a href="/auth/login" class="btn btn-sm">Войти</a>
        <a href="/auth/register" class="btn btn-sm btn-primary">Регистрация</a>
      {{/if}}
    </nav>
  </div>
</header>
