<footer class="footer">
  <div class="container">
    <p>&copy; 2026 Mamont Forum. Все права защищены.</p>
    {{#if elapsedTime}}
      <p class="elapsed-time">
        Сервер: <span>{{elapsedTime}} мс</span>
        · Клиент: <span id="client-elapsed">—</span>
      </p>
    {{/if}}
  </div>
</footer>
<script>
  window.addEventListener('load', function () {
    var nav = performance.getEntriesByType('navigation')[0];
    var el = document.getElementById('client-elapsed');
    if (nav && el) {
      el.textContent = Math.round(nav.responseEnd - nav.requestStart) + ' мс';
    }
  });
</script>
